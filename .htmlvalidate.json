{
  "extends": ["html-validate:recommended"],
  "elements": ["html5"],
  "transform": {
    "^node_modules/": "off"
  },
  "rules": {
    "void-style": "off",
    "no-raw-characters": "off",
    "no-inline-style": "off",
    "no-implicit-close": "off",
    "prefer-native-element": "off",
    "wcag/h37": "off",
    "wcag/h63": "off"
  }
}

